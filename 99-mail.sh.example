#!/bin/bash

sleep 5

#MAILTO="admins@example.com"
MAILTO="admin@example.com   # <-- adjust"
FROM="certdeploy@example.com   # <-- adjust"
HOSTNAME="$(hostname -f)"
SUBJECT="Zertifikats-Deployment am $(date '+%d.%m.%Y') auf $HOSTNAME"

LOGFILE="/log/certuser/deploy-status.log"
CERTFILE="/path/to/acme.sh   # <-- adjust/example.com/fullchain.cer"

# Zertifikatsablaufdatum extrahieren
expiry=$(openssl x509 -enddate -noout -in "$CERTFILE" | cut -d= -f2)
expiry_formatted=$(date -d "$expiry" '+%d.%m.%Y %H:%M:%S')

# HTML-Mailaufbau
body="<html><body>"
body+="<h2>Zertifikats-Deploymentbericht – $HOSTNAME</h2>"
body+="<p><strong>Datum:</strong> $(date '+%d.%m.%Y %H:%M:%S')</p>"
body+="<p><strong>Zertifikat gültig bis:</strong> $expiry_formatted</p>"

# Tabellenkopf
body+="<table border='1' cellpadding='6' cellspacing='0' style='border-collapse: collapse;'>"
body+="<tr style='background-color:#f2f2f2;'><th>Komponente</th><th>Host</th><th>Status</th></tr>"

total=0
ok=0
fail=0

if [[ -f "$LOGFILE" ]]; then
  while read -r line; do
    [[ -z "$line" ]] && continue

    total=$((total + 1))
    status="❓ Unbekannt"
    bgcolor="#fff3cd"

    if [[ "$line" == *"✅ Erfolgreich"* ]]; then
      status="✅ Erfolgreich"
      bgcolor="#d4edda"
      ok=$((ok + 1))
    elif [[ "$line" == *"❌ Fehler"* ]]; then
      status="❌ Fehler"
      bgcolor="#f8d7da"
      fail=$((fail + 1))
    fi

    component=$(echo "$line" | awk '{print $1}')
    host=$(echo "$line" | awk '{print $2}')

    body+="<tr style='background-color:$bgcolor;'><td>$component</td><td>$host</td><td>$status</td></tr>"
  done < "$LOGFILE"
else
  body+="<tr><td colspan='3'><em>Keine Logdatei gefunden</em></td></tr>"
fi

# Statistikzeile anhängen
body+="</table>"
if (( total > 0 )); then
  body+="<p style='margin-top:10px;'><strong>Gesamt:</strong> $total &nbsp;&nbsp;✅ <strong>Erfolgreich:</strong> $ok &nbsp;&nbsp;❌ <strong>Fehlgeschlagen:</strong> $fail</p>"
fi

body+="</body></html>"

# Mail versenden
echo "$body" | mail -a "Content-Type: text/html" -s "$SUBJECT" -r "$FROM" "$MAILTO"

echo -e "Status-Mail erfolgreich an $MAILTO versendet."

# Logdatei optional löschen
# rm -f "$LOGFILE"
